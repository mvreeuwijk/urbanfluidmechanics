---
import { NAV, SITE, MAILING_LIST_URL } from '../consts';
import { withBase } from '../lib/url';
import Logo from './Logo.astro';

// active-link matching against the current path (base-aware)
const norm = (p: string) => p.replace(/\/$/, '') || '/';
const path = norm(Astro.url.pathname);
const isActive = (href: string) => {
  const h = norm(withBase(href));
  return path === h || path.startsWith(h + '/');
};
---
<header class="nav">
  <div class="wrap nav-in">
    <a class="brand" href={withBase('/')}>
      <Logo class="glyph" />
      <span class="brand-txt">{SITE.name}<small>{SITE.sub}</small></span>
    </a>

    <button class="menu-btn" type="button" aria-label="Toggle menu" aria-expanded="false" data-menu-btn>
      <span></span><span></span><span></span>
    </button>

    <nav class="links" data-menu aria-label="Primary">
      {NAV.map((item) => (
        <a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
      <a class="cta" href={MAILING_LIST_URL} target="_blank" rel="noopener">Join the list</a>
    </nav>

    <button class="theme-btn" type="button" aria-label="Toggle light / dark theme" data-theme-toggle>
      <svg class="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      <svg class="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
    </button>
  </div>
</header>

<style>
  .nav { position: sticky; top: 0; z-index: 30; border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(10px); }
  .nav-in { display: flex; align-items: center; gap: 20px; height: 64px; }
  .brand { display: flex; align-items: center; gap: 11px; color: var(--ink); }
  .brand:hover { text-decoration: none; }
  .brand-txt { font-family: var(--serif); font-weight: 600; font-size: 17px; letter-spacing: -.01em; line-height: 1.05; }
  .brand-txt small { display: block; font-family: var(--sans); font-weight: 600; font-size: 10px;
    letter-spacing: .14em; text-transform: uppercase; color: var(--faint); }

  .links { display: flex; align-items: center; gap: 22px; margin-left: auto; }
  .links a { font-size: 14.5px; font-weight: 500; color: var(--sub); }
  .links a:hover { color: var(--ink); text-decoration: none; }
  .links a[aria-current="page"] { color: var(--ink); font-weight: 700; }
  .links .cta { padding: 8px 15px; border-radius: 7px; background: var(--teal); color: #fff; font-weight: 700; font-size: 13.5px; }
  .links .cta:hover { background: var(--teal-deep); }

  .theme-btn, .menu-btn { background: none; border: 1px solid var(--line); border-radius: 8px; color: var(--sub);
    cursor: pointer; display: grid; place-items: center; }
  .theme-btn { width: 38px; height: 38px; }
  .theme-btn:hover { color: var(--ink); border-color: var(--teal); }
  .theme-btn .moon { display: none; } .theme-btn .sun { display: block; }
  :root[data-theme="dark"] .theme-btn .moon { display: block; }
  :root[data-theme="dark"] .theme-btn .sun { display: none; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .theme-btn .moon { display: block; }
    :root:not([data-theme="light"]) .theme-btn .sun { display: none; }
  }

  .menu-btn { display: none; width: 40px; height: 38px; margin-left: auto; flex-direction: column; gap: 4px; }
  .menu-btn span { width: 18px; height: 2px; background: currentColor; border-radius: 2px; }

  @media (max-width: 780px) {
    .menu-btn { display: flex; }
    .links { position: absolute; top: 64px; left: 0; right: 0; flex-direction: column; align-items: stretch;
      gap: 0; background: var(--bg); border-bottom: 1px solid var(--line); padding: 8px 24px 16px; margin: 0;
      display: none; }
    .links[data-open] { display: flex; }
    .links a { padding: 11px 0; border-bottom: 1px solid var(--line); }
    .links .cta { margin-top: 12px; text-align: center; border-bottom: none; }
    .theme-btn { margin-left: 4px; }
  }
</style>

<script>
  // mobile menu
  const btn = document.querySelector('[data-menu-btn]');
  const menu = document.querySelector('[data-menu]');
  btn?.addEventListener('click', () => {
    const open = menu?.toggleAttribute('data-open');
    btn.setAttribute('aria-expanded', String(!!open));
  });
  // theme toggle: cycle explicit light/dark, persisted
  document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
    const root = document.documentElement;
    const current = root.getAttribute('data-theme')
      ?? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    const next = current === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try { localStorage.setItem('ufm-theme', next); } catch {}
  });
</script>
