---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  image?: ImageMetadata;   // optional background banner (switches to image/hero mode)
  imageAlt?: string;
}
const { eyebrow, title, lead, image, imageAlt = '' } = Astro.props;
---
{image ? (
  <div class="page-header has-image">
    <Image class="ph-bg" src={image} alt={imageAlt} widths={[768, 1280, 1920]} sizes="100vw" loading="eager" />
    <div class="ph-veil"></div>
    <div class="wrap ph-in">
      {eyebrow && <div class="eyebrow light">{eyebrow}</div>}
      <h1>{title}</h1>
      {lead && <p class="lead">{lead}</p>}
      <slot />
    </div>
  </div>
) : (
  <div class="page-header">
    <div class="wrap">
      {eyebrow && <div class="eyebrow">{eyebrow}</div>}
      <h1>{title}</h1>
      {lead && <p class="lead">{lead}</p>}
      <slot />
    </div>
  </div>
)}

<style>
  .page-header { background: var(--paper); border-bottom: 1px solid var(--line); padding: 44px 0 34px; }
  .eyebrow { margin-bottom: 8px; }
  h1 { font-size: clamp(28px, 4vw, 40px); }
  .lead { color: var(--sub); margin-top: 12px; max-width: 68ch; font-size: 16.5px; }

  /* image / hero mode */
  .has-image { position: relative; overflow: hidden; background: #0b1f2a; border-bottom: none; padding: 0; min-height: 300px; display: flex; align-items: flex-end; }
  .ph-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 55%; }
  .ph-veil { position: absolute; inset: 0; background:
      linear-gradient(180deg, rgba(9,28,38,.2) 0%, rgba(9,25,35,.4) 45%, rgba(8,22,31,.85) 100%),
      linear-gradient(90deg, rgba(8,22,31,.7) 0%, rgba(8,22,31,.1) 60%, transparent 100%); }
  .ph-in { position: relative; padding: 52px 0 34px; color: #eef4f6; }
  .has-image h1 { color: #fff; }
  .has-image .lead { color: #cfdde3; }
  .eyebrow.light { color: #7fd6dc; margin-bottom: 8px; }
</style>
