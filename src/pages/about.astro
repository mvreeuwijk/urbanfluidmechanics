---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import { CONTACTS, MAILING_LIST_URL } from '../consts';
import { withBase } from '../lib/url';

// Curated external resources (from the current site's "Other Resources").
const resources = [
  { name: 'UK Fluids Network', url: 'https://fluids.ac.uk/', note: 'The network within which the group was founded.' },
  { name: 'ERCOFTAC / QNET-CFD Knowledge Base', url: 'https://www.ercoftac.org/', note: 'Best-practice and validation cases for CFD.' },
  { name: 'CEDA — Centre for Environmental Data Analysis', url: 'https://www.ceda.ac.uk/', note: 'Repository hosting many UK atmospheric datasets.' },
  { name: 'AIJ Benchmarks (Architectural Institute of Japan)', url: 'https://www.aij.or.jp/jpn/publish/cfdguide/index_e.htm', note: 'Standard cases for pedestrian-wind CFD.' },
];
---
<Base title="About" description="The history and organisation of the Urban Fluid Mechanics community.">
  <PageHeader
    eyebrow="About the group"
    title="An independent, open community"
  />
  <section class="section">
    <div class="wrap prose">
      <h2>Who we are</h2>
      <p>Urban Fluid Mechanics is an open research community whose interests cover the broad range of issues
        associated with flows in urban areas — the turbulent transport of momentum, heat and pollutants across
        every scale of the city, from inside and between buildings, through the urban canopy, and up into the
        atmospheric boundary layer. Our scope ranges from fundamental to applied research, with an emphasis on
        experimental, numerical and theoretical approaches.</p>

      <h2>Our history</h2>
      <p>The community began as a <strong>Special Interest Group of the UK Fluids Network</strong>, funded by the
        Engineering and Physical Sciences Research Council (EPSRC). That grant has since concluded. Rather than
        wind the group down, we have continued <strong>independently</strong> — the meetings, the data portal and
        the mailing list all carry on, sustained by the community itself.</p>
      <p>We remain open to everyone working on the fluid mechanics of cities: universities, industry and
        government, in the UK and internationally. There is no membership fee. Anyone is welcome to
        <a href={MAILING_LIST_URL} target="_blank" rel="noopener">join the mailing list</a>, attend a meeting, and
        contribute datasets to the portal.</p>

      <h2>How it runs</h2>
      <p>The group meets once or twice a year — typically around 50 participants — hosted in rotation by member
        institutions. Talks and slides from each meeting are archived on the <a href={withBase('/meetings')}>Meetings</a> page.
        The <a href={withBase('/data-portal')}>Data Portal</a> collects datasets from field, laboratory and CFD studies so
        they can be found, compared and reused.</p>

      <h2>Organisers &amp; contact</h2>
      <p>For anything about the group, please contact:</p>
      <ul class="contacts">
        {CONTACTS.map((c) => (
          <li><a href={`mailto:${c.email}`}>{c.name}</a> · {c.institution}</li>
        ))}
      </ul>

      <h2>Other resources</h2>
      <ul class="resources">
        {resources.map((r) => (
          <li><a href={r.url} target="_blank" rel="noopener">{r.name}</a> — <span>{r.note}</span></li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<style>
  .prose { max-width: 74ch; }
  .prose h2 { font-size: 22px; margin: 34px 0 12px; }
  .prose h2:first-child { margin-top: 0; }
  .prose p { color: var(--sub); margin-bottom: 14px; }
  .contacts, .resources { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 8px; color: var(--sub); }
  .resources span { color: var(--faint); }
</style>
