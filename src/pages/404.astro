---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/url';
---
<Base title="Page not found">
  <section class="section notfound">
    <div class="wrap">
      <p class="code mono">404</p>
      <h1>Page not found</h1>
      <p class="lead">The page you were looking for doesn’t exist or may have moved.</p>
      <p><a class="btn primary" href={withBase('/')}>Back to home →</a></p>
    </div>
  </section>
</Base>
<style>
  .notfound { padding-block: 90px; text-align: center; }
  .code { font-size: 64px; font-weight: 700; color: var(--teal); opacity: .5; }
  .notfound h1 { font-size: 32px; margin: 6px 0 12px; }
  .lead { color: var(--sub); margin-bottom: 24px; }
</style>
