---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { CHALLENGES } from '../data/challenges';
import { getMeetings, formatMeetingDate, talkCount } from '../data/meetings';
import { MEMBERS, MEMBER_COUNT } from '../data/members';
import { datasets, primaryType, TYPE_LABEL, facet } from '../lib/datasets';
import { MAILING_LIST_URL } from '../consts';
import { withBase } from '../lib/url';
import heroImg from '../assets/images/wind-tunnel-model.jpg';

const meetings = await getMeetings();
const recentMeetings = meetings.slice(0, 3);
const meetingCount = meetings.length;

// Portal preview — driven by the real dataset records (full data lives on /data-portal).
const methodOrder = ['field', 'lab', 'cfd'] as const;
const methodCounts = { field: 0, lab: 0, cfd: 0 };
datasets.forEach((d) => methodCounts[primaryType(d)]++);
const maxMethod = Math.max(...Object.values(methodCounts));

const nCities = new Set(datasets.map((d) => d.city)).size;
const nCountries = new Set(datasets.map((d) => d.country)).size;
const nInstitutions = facet('institution').length;

const qCount: Record<string, number> = {};
datasets.forEach((d) => d.quantities.forEach((q) => (qCount[q] = (qCount[q] || 0) + 1)));
const topQuantities = Object.entries(qCount).sort((a, b) => b[1] - a[1]).slice(0, 5).map(([q]) => q);

// A representative handful across methods for the preview table.
const byType = (t: 'field' | 'lab' | 'cfd') => datasets.filter((d) => primaryType(d) === t);
const sample = [byType('field')[0], byType('lab')[0], byType('cfd')[0], byType('field')[1], byType('lab')[1]]
  .filter(Boolean);
---
<Base>
  <!-- ============ HERO ============ -->
  <div class="hero">
    <Image class="scene" src={heroImg} alt="A scaled physical model of a city under study in a wind tunnel"
      widths={[768, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" />
    <div class="veil"></div>
    <div class="wrap hero-in">
      <div class="eyebrow hero-eyebrow">Open research community</div>
      <h1>The fluid mechanics of the urban environment.</h1>
      <p class="lede">Studying the turbulent transport of momentum, heat and pollutants across every scale
        of the city — inside and between buildings, through the urban canopy, and up into the atmospheric
        boundary layer — and sharing the data, models and meetings behind the science.</p>
      <div class="cta">
        <a class="btn primary" href={withBase('/data-portal')}>Explore the data portal →</a>
        <a class="btn ghost onhero" href={withBase('/meetings')}>Meetings &amp; talks</a>
      </div>
    </div>
  </div>

  <!-- ============ STATS ============ -->
  <div class="statbar"><div class="wrap">
    <div class="stat"><b>{MEMBER_COUNT}</b><span>Members</span></div>
    <div class="stat"><b>{MEMBERS.length}</b><span>Institutions &amp; companies</span></div>
    <div class="stat"><b>{meetingCount}</b><span>Meetings since 2017</span></div>
  </div></div>

  <!-- ============ CHALLENGES ============ -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head"><div class="row">
        <h2>Five challenge areas</h2><span class="eyebrow">Research scope</span>
      </div>
        <p class="lead">Spanning fundamental to applied research — experimental, numerical and theoretical —
          organised around five shared challenges, revised in 2025 to reflect net zero, resilience and the
          rise of data-driven methods. <a href={withBase('/research')}>Read more →</a></p>
      </div>
      <div class="challenges">
        {CHALLENGES.map((c) => (
          <a class="ch" href={withBase(`/research#${c.id}`)}>
            <span class="tag mono">{c.id}</span>
            <h3>{c.title}</h3>
            <p>{c.short}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ DATA PORTAL PREVIEW ============ -->
  <section class="section alt">
    <div class="wrap">
      <div class="sec-head"><div class="row">
        <h2>Explore the datasets</h2><span class="eyebrow">Data portal</span>
      </div>
        <p class="lead">Field, laboratory and CFD studies of urban flow — searchable, filterable and mapped.
          <strong>{datasets.length} datasets</strong> from {nCities} cities across {nCountries} countries power
          the table, the map and the linked papers.</p>
      </div>
      <div class="portal-grid">
        <div class="panel">
          <div class="panel-top"><span class="ttl">Datasets</span>
            <a class="count link-arrow" href={withBase('/data-portal')}>Open the full portal →</a></div>
          <table>
            <thead><tr><th>Dataset</th><th>Type</th><th>City</th></tr></thead>
            <tbody>
              {sample.map((d) => (
                <tr>
                  <td class="dsname">{d.projectName}</td>
                  <td><span class={`chip ${primaryType(d)}`}>{TYPE_LABEL[primaryType(d)]}</span></td>
                  <td>{d.city}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="panel glance">
          <div class="panel-top"><span class="ttl">At a glance</span>
            <a class="count link-arrow" href={withBase('/data-portal/map')}>Map view →</a></div>
          <div class="glance-body">
            <div class="metric">
              <div class="metric-h">By method</div>
              <ul class="bars">
                {methodOrder.map((t) => (
                  <li>
                    <span class="bl">{TYPE_LABEL[t]}</span>
                    <span class="track"><i class={t} style={`width:${Math.round(methodCounts[t] / maxMethod * 100)}%`}></i></span>
                    <span class="bv mono">{methodCounts[t]}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="cover">
              <div><b>{nCities}</b><span>cities</span></div>
              <div><b>{nCountries}</b><span>countries</span></div>
              <div><b>{nInstitutions}</b><span>institutions</span></div>
            </div>
            <div class="metric">
              <div class="metric-h">Most-measured quantities</div>
              <div class="qchips">
                {topQuantities.map((q) => <span class="qchip">{q}</span>)}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MEETINGS ============ -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head"><div class="row">
        <h2>Meetings &amp; presentations</h2><span class="eyebrow">Community &amp; outputs</span>
      </div>
        <p class="lead">The group meets once or twice a year — typically around 50 participants across
          universities, industry and government. Talks and slides from each meeting are archived here as a
          lasting record of the field.</p>
      </div>
      <div class="mgrid">
        {recentMeetings.map((m) => (
          <a class="mcard" href={withBase(`/meetings/${m.id}`)}>
            <div class="mdate mono">{formatMeetingDate(m.data.start, m.data.end)}</div>
            <h3>{m.data.label}</h3>
            <div class="mloc">{m.data.host}</div>
            <div class="mfoot">
              {talkCount(m) ? <span class="talks">{talkCount(m)} talks</span> : <span></span>}
              <span class="go">Programme &amp; slides →</span>
            </div>
          </a>
        ))}
      </div>
      <p class="meet-foot"><a class="link-arrow" href={withBase('/meetings')}>Browse all {meetingCount} meetings →</a></p>
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="section alt">
    <div class="wrap">
      <div class="sec-head"><div class="row">
        <h2>An independent, open community</h2><span class="eyebrow">About the group</span>
      </div></div>
      <p class="lead" style="max-width:74ch;font-size:16px">Urban Fluid Mechanics began as a Special Interest
        Group of the <strong>UK Fluids Network</strong>, funded by EPSRC. That grant has since concluded — but
        the community it created carries on independently. We remain open to all: universities, industry and
        government, in the UK and beyond. There is no membership fee; anyone working on the fluid mechanics of
        cities is welcome to <a href={MAILING_LIST_URL} target="_blank" rel="noopener">join the mailing list</a>,
        come to a meeting, and add datasets to the portal.</p>
      <p style="margin-top:18px"><a class="link-arrow" href={withBase('/about')}>Read the full story &amp; how to get involved →</a></p>
    </div>
  </section>
</Base>

<style>
  /* hero */
  .hero { position: relative; overflow: hidden; background: #0b1f2a; min-height: 460px; display: flex; align-items: flex-end; }
  .scene { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 60%; }
  .veil { position: absolute; inset: 0; background:
      linear-gradient(180deg, rgba(9,28,38,.15) 0%, rgba(9,25,35,.35) 45%, rgba(8,22,31,.86) 100%),
      linear-gradient(90deg, rgba(8,22,31,.75) 0%, rgba(8,22,31,.15) 60%, transparent 100%); }
  .hero-in { position: relative; padding: 60px 0 44px; color: #eef4f6; }
  .hero-eyebrow { color: #7fd6dc; }
  .hero h1 { font-size: clamp(27px, 3.6vw, 40px); line-height: 1.08; color: #fff; max-width: 22ch; margin-top: 12px; }
  .hero .lede { font-size: clamp(15px, 1.7vw, 17.5px); color: #cfdde3; max-width: 58ch; margin-top: 16px; }
  .hero .cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 26px; }
  .btn.ghost.onhero { border-color: rgba(255,255,255,.4); color: #fff; background: rgba(255,255,255,.06); }
  .btn.ghost.onhero:hover { border-color: #fff; }
  @media (prefers-reduced-motion: no-preference) {
    .streams path { stroke-dasharray: 5 9; animation: flowdash 6s linear infinite; }
    @keyframes flowdash { to { stroke-dashoffset: -160; } }
  }

  /* stats */
  .statbar { background: var(--paper); border-bottom: 1px solid var(--line); }
  .statbar .wrap { display: flex; flex-wrap: wrap; align-items: baseline; gap: 9px 0; padding: 13px 24px; }
  .stat { display: flex; align-items: baseline; gap: 8px; padding: 0 22px; border-left: 1px solid var(--line); }
  .stat:first-child { padding-left: 0; border-left: none; }
  .stat b { font-family: var(--serif); font-size: 21px; font-weight: 600; color: var(--ink); }
  .stat span { font-size: 12.5px; color: var(--sub); font-weight: 600; }

  .lead a { font-weight: 600; }

  /* challenges */
  .challenges { display: grid; grid-template-columns: repeat(5, 1fr); }
  @media (max-width: 980px) { .challenges { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 640px) { .challenges { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 440px) { .challenges { grid-template-columns: 1fr; } }
  .ch { padding: 20px 18px; border-left: 1px solid var(--line); color: var(--ink); }
  .ch:first-child { border-left: none; padding-left: 0; }
  .ch:hover { text-decoration: none; background: var(--card); }
  .ch .tag { font-size: 12px; font-weight: 700; color: var(--teal); }
  .ch h3 { font-size: 16px; margin: 8px 0 7px; line-height: 1.18; }
  .ch p { font-size: 12.5px; color: var(--sub); line-height: 1.5; }

  /* portal preview */
  .portal-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; align-items: stretch; }
  @media (max-width: 820px) { .portal-grid { grid-template-columns: 1fr; } }
  .panel { background: var(--card); border: 1px solid var(--line); border-radius: 6px; box-shadow: var(--shadow); overflow: hidden; }
  .panel-top { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 13px 16px; border-bottom: 1px solid var(--line); }
  .panel-top .ttl { font-family: var(--serif); font-weight: 600; font-size: 15.5px; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead th { font-size: 10.5px; letter-spacing: .06em; text-transform: uppercase; color: var(--faint); text-align: left; padding: 11px 16px 8px; font-weight: 700; }
  tbody td { padding: 10px 16px; border-top: 1px solid var(--line); }
  tbody tr:hover { background: var(--paper); }
  .dsname { font-weight: 600; }

  /* portal — at a glance */
  .glance { display: flex; flex-direction: column; }
  .glance-body { padding: 16px; display: flex; flex-direction: column; gap: 18px; }
  .metric-h { font-size: 10.5px; letter-spacing: .06em; text-transform: uppercase; color: var(--faint);
    font-weight: 700; margin-bottom: 9px; }
  .bars { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .bars li { display: grid; grid-template-columns: 46px 1fr 22px; align-items: center; gap: 10px; }
  .bl { font-size: 12.5px; font-weight: 600; color: var(--sub); }
  .track { height: 9px; background: var(--paper); border-radius: 999px; overflow: hidden; }
  .track i { display: block; height: 100%; border-radius: 999px; }
  .track i.field { background: var(--sand); }
  .track i.lab   { background: var(--teal); }
  .track i.cfd   { background: var(--green); }
  .bv { font-size: 12.5px; color: var(--ink); text-align: right; font-variant-numeric: tabular-nums; }
  .cover { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
    padding: 14px 0; border-block: 1px solid var(--line); }
  .cover div { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .cover b { font-family: var(--serif); font-size: 22px; font-weight: 600; color: var(--ink); line-height: 1; }
  .cover span { font-size: 11px; color: var(--faint); font-weight: 600; margin-top: 4px; }
  .qchips { display: flex; flex-wrap: wrap; gap: 6px; }
  .qchip { font-size: 12px; font-weight: 600; color: var(--sub); background: var(--paper);
    border: 1px solid var(--line); border-radius: 999px; padding: 4px 11px; }

  /* meetings */
  .mgrid { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--line); }
  @media (max-width: 760px) { .mgrid { grid-template-columns: 1fr; } }
  .mcard { padding: 20px; border-left: 1px solid var(--line); border-bottom: 1px solid var(--line); display: flex; flex-direction: column; gap: 7px; color: var(--ink); }
  .mcard:first-child { border-left: none; padding-left: 0; }
  @media (max-width: 760px) { .mcard { border-left: none; padding-left: 0; } }
  .mcard:hover { text-decoration: none; background: var(--card); }
  .mdate { font-size: 12px; color: var(--faint); font-weight: 700; }
  .mcard h3 { font-size: 17px; }
  .mloc { font-size: 13px; color: var(--sub); }
  .mfoot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; padding-top: 10px; }
  .talks { font-size: 11.5px; font-weight: 700; color: var(--teal-deep); background: var(--teal-soft); padding: 3px 9px; border-radius: 4px; }
  .go { font-size: 13px; font-weight: 700; color: var(--teal); }
  .meet-foot { margin-top: 20px; text-align: right; }
</style>
