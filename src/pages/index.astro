---
import Base from '../layouts/Base.astro';
import { CHALLENGES } from '../data/challenges';
import { MEETINGS, meetingsByDateDesc, formatMeetingDate } from '../data/meetings';
import { MAILING_LIST_URL } from '../consts';

const recentMeetings = meetingsByDateDesc.slice(0, 3);
const meetingCount = MEETINGS.length;

// Small illustrative teaser for the portal preview (full data lives on /data-portal).
const teaser = [
  { name: 'ACTUAL — Urban Atmospheric Laboratory', method: 'field', tag: 'Field', city: 'London' },
  { name: 'Character of rough-wall BLs', method: 'lab', tag: 'Lab', city: 'Southampton' },
  { name: 'CWE2000 cube (Silsoe)', method: 'cfd', tag: 'CFD', city: 'Silsoe' },
  { name: 'ClearfLo air-pollution campaign', method: 'field', tag: 'Field', city: 'London' },
  { name: 'CUBE — idealised building PIV', method: 'lab', tag: 'Lab', city: 'London' },
];
---
<Base>
  <!-- ============ HERO ============ -->
  <div class="hero">
    <svg class="scene" viewBox="0 0 1200 500" preserveAspectRatio="xMidYMax slice" aria-hidden="true">
      <defs>
        <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#12384a" /><stop offset=".45" stop-color="#1c556a" />
          <stop offset=".8" stop-color="#3f7f8a" /><stop offset="1" stop-color="#6ba7ad" />
        </linearGradient>
        <radialGradient id="sun" cx="72%" cy="26%" r="34%">
          <stop offset="0" stop-color="#ffe4c2" stop-opacity=".85" /><stop offset="1" stop-color="#ffe4c2" stop-opacity="0" />
        </radialGradient>
      </defs>
      <rect width="1200" height="500" fill="url(#sky)" />
      <rect width="1200" height="500" fill="url(#sun)" />
      <g fill="#2b5c6c" opacity=".55">
        <rect x="40" y="300" width="70" height="200" /><rect x="130" y="260" width="55" height="240" />
        <rect x="210" y="320" width="80" height="180" /><rect x="320" y="280" width="48" height="220" />
        <rect x="700" y="300" width="70" height="200" /><rect x="800" y="270" width="60" height="230" />
        <rect x="900" y="315" width="85" height="185" /><rect x="1010" y="285" width="55" height="215" /><rect x="1090" y="320" width="70" height="180" />
      </g>
      <g fill="#1c4655" opacity=".82">
        <rect x="90" y="340" width="70" height="160" /><rect x="180" y="300" width="64" height="200" />
        <rect x="270" y="360" width="90" height="140" /><rect x="380" y="320" width="70" height="180" />
        <rect x="470" y="270" width="58" height="230" /><rect x="560" y="340" width="80" height="160" />
        <rect x="660" y="310" width="66" height="190" /><rect x="760" y="350" width="88" height="150" />
        <rect x="870" y="300" width="60" height="200" /><rect x="960" y="345" width="78" height="155" /><rect x="1060" y="315" width="70" height="185" />
      </g>
      <g fill="#0c2a35">
        <rect x="20" y="380" width="96" height="120" /><rect x="130" y="350" width="80" height="150" />
        <rect x="225" y="400" width="70" height="100" /><rect x="310" y="360" width="104" height="140" />
        <rect x="430" y="330" width="72" height="170" /><rect x="520" y="390" width="96" height="110" />
        <rect x="630" y="355" width="84" height="145" /><rect x="730" y="405" width="70" height="95" />
        <rect x="815" y="345" width="100" height="155" /><rect x="930" y="385" width="86" height="115" /><rect x="1035" y="360" width="92" height="140" />
      </g>
      <g fill="#ffd9a8" opacity=".5">
        <rect x="330" y="380" width="6" height="8" /><rect x="345" y="380" width="6" height="8" /><rect x="330" y="400" width="6" height="8" /><rect x="345" y="400" width="6" height="8" />
        <rect x="450" y="360" width="6" height="8" /><rect x="450" y="380" width="6" height="8" /><rect x="835" y="370" width="6" height="8" /><rect x="850" y="370" width="6" height="8" /><rect x="835" y="392" width="6" height="8" />
      </g>
      <g class="streams" stroke="#bfe6ea" fill="none" stroke-width="1.6" opacity=".5" stroke-linecap="round">
        <path d="M-20 120 C 300 80, 560 150, 900 100 S 1240 95 1240 120" />
        <path d="M-20 180 C 340 140, 620 205, 980 160 S 1240 160 1240 185" style="animation-delay:-2s" />
      </g>
    </svg>
    <div class="veil"></div>
    <div class="wrap hero-in">
      <div class="eyebrow hero-eyebrow">Open research community</div>
      <h1>The fluid mechanics of the urban environment.</h1>
      <p class="lede">Studying the turbulent transport of momentum, heat and pollutants across every scale
        of the city — inside and between buildings, through the urban canopy, and up into the atmospheric
        boundary layer — and sharing the data, models and meetings behind the science.</p>
      <div class="cta">
        <a class="btn primary" href="/data-portal">Explore the data portal →</a>
        <a class="btn ghost onhero" href="/meetings">Meetings &amp; talks</a>
      </div>
    </div>
  </div>

  <!-- ============ STATS ============ -->
  <div class="statbar"><div class="wrap">
    <div class="stat"><b>250+</b><span>Members</span></div>
    <div class="stat"><b>40+</b><span>Institutions &amp; companies</span></div>
    <div class="stat"><b>{meetingCount}</b><span>Meetings since 2017</span></div>
  </div></div>

  <!-- ============ CHALLENGES ============ -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head"><div class="row">
        <h2>Five challenge areas</h2><span class="eyebrow">Research scope · rev. 2025</span>
      </div>
        <p class="lead">Spanning fundamental to applied research — experimental, numerical and theoretical —
          organised around five shared challenges, revised in 2025 to reflect net zero, resilience and the
          rise of data-driven methods. <a href="/research">Read more →</a></p>
      </div>
      <div class="challenges">
        {CHALLENGES.map((c) => (
          <a class="ch" href={`/research#${c.id}`}>
            <span class="tag mono">{c.id}</span>
            <h3>{c.title}</h3>
            <p>{c.short}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ DATA PORTAL PREVIEW ============ -->
  <section class="section alt">
    <div class="wrap">
      <div class="sec-head"><div class="row">
        <h2>Find urban fluid mechanics datasets</h2><span class="eyebrow">Data portal</span>
      </div>
        <p class="lead">Field experiments, laboratory &amp; physical-model studies and CFD — searchable,
          filterable, and mapped. The same records power the table, the map and the linked papers.</p>
      </div>
      <div class="portal-grid">
        <div class="panel">
          <div class="panel-top"><span class="ttl">Datasets</span>
            <a class="count link-arrow" href="/data-portal">Open the full portal →</a></div>
          <table>
            <thead><tr><th>Dataset</th><th>Type</th><th>City</th></tr></thead>
            <tbody>
              {teaser.map((d) => (
                <tr><td class="dsname">{d.name}</td><td><span class={`chip ${d.method}`}>{d.tag}</span></td><td>{d.city}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <a class="panel map" href="/data-portal/map" aria-label="Open the map view">
          <svg viewBox="0 0 400 320" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <g stroke="var(--line)" stroke-width="1" opacity=".8">
              <path d="M0 64 H400 M0 128 H400 M0 192 H400 M0 256 H400" fill="none" />
              <path d="M80 0 V320 M160 0 V320 M240 0 V320 M320 0 V320" fill="none" />
            </g>
            <path d="M150 90 q30 -26 70 -10 q40 -6 55 22 q22 34 -8 66 q-15 46 -70 40 q-52 6 -70 -34 q-24 -40 8 -68 q7 -22 25 -16 z"
              fill="color-mix(in srgb, var(--teal) 15%, transparent)" stroke="color-mix(in srgb, var(--teal) 42%, transparent)" stroke-width="1.5" />
          </svg>
          <span class="pin" style="left:47%;top:52%"><i style="background:var(--teal)"></i></span>
          <span class="pin" style="left:54%;top:42%"><i style="background:var(--sand)"></i></span>
          <span class="pin" style="left:60%;top:62%"><i style="background:var(--green)"></i></span>
          <span class="pin" style="left:43%;top:64%"><i style="background:var(--green)"></i></span>
          <span class="pin" style="left:57%;top:34%"><i style="background:var(--sand)"></i></span>
          <span class="map-cta">Map view →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ MEETINGS ============ -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head"><div class="row">
        <h2>Meetings &amp; presentations</h2><span class="eyebrow">Community &amp; outputs</span>
      </div>
        <p class="lead">The group meets once or twice a year — typically around 50 participants across
          universities, industry and government. Talks and slides from each meeting are archived here as a
          lasting record of the field.</p>
      </div>
      <div class="mgrid">
        {recentMeetings.map((m) => (
          <a class="mcard" href={`/meetings/${m.slug}`}>
            <div class="mdate mono">{formatMeetingDate(m)}</div>
            <h3>{m.label}</h3>
            <div class="mloc">{m.host}</div>
            <div class="mfoot">
              {m.talksCount ? <span class="talks">{m.talksCount} talks</span> : <span></span>}
              <span class="go">Programme &amp; slides →</span>
            </div>
          </a>
        ))}
      </div>
      <p class="meet-foot"><a class="link-arrow" href="/meetings">Browse all {meetingCount} meetings →</a></p>
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="section alt">
    <div class="wrap">
      <div class="sec-head"><div class="row">
        <h2>An independent, open community</h2><span class="eyebrow">About the group</span>
      </div></div>
      <p class="lead" style="max-width:74ch;font-size:16px">Urban Fluid Mechanics began as a Special Interest
        Group of the <strong>UK Fluids Network</strong>, funded by EPSRC. That grant has since concluded — but
        the community it created carries on independently. We remain open to all: universities, industry and
        government, in the UK and beyond. There is no membership fee; anyone working on the fluid mechanics of
        cities is welcome to <a href={MAILING_LIST_URL} target="_blank" rel="noopener">join the mailing list</a>,
        come to a meeting, and add datasets to the portal.</p>
      <p style="margin-top:18px"><a class="link-arrow" href="/about">Read the full story &amp; how to get involved →</a></p>
    </div>
  </section>
</Base>

<style>
  /* hero */
  .hero { position: relative; overflow: hidden; background: #0b1f2a; min-height: 460px; display: flex; align-items: flex-end; }
  .scene { position: absolute; inset: 0; width: 100%; height: 100%; }
  .veil { position: absolute; inset: 0; background:
      linear-gradient(180deg, rgba(9,28,38,.15) 0%, rgba(9,25,35,.35) 45%, rgba(8,22,31,.86) 100%),
      linear-gradient(90deg, rgba(8,22,31,.75) 0%, rgba(8,22,31,.15) 60%, transparent 100%); }
  .hero-in { position: relative; padding: 60px 0 44px; color: #eef4f6; }
  .hero-eyebrow { color: #7fd6dc; }
  .hero h1 { font-size: clamp(30px, 4.4vw, 48px); line-height: 1.05; color: #fff; max-width: 18ch; margin-top: 12px; }
  .hero .lede { font-size: clamp(15px, 1.7vw, 17.5px); color: #cfdde3; max-width: 58ch; margin-top: 16px; }
  .hero .cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 26px; }
  .btn.ghost.onhero { border-color: rgba(255,255,255,.4); color: #fff; background: rgba(255,255,255,.06); }
  .btn.ghost.onhero:hover { border-color: #fff; }
  @media (prefers-reduced-motion: no-preference) {
    .streams path { stroke-dasharray: 5 9; animation: flowdash 6s linear infinite; }
    @keyframes flowdash { to { stroke-dashoffset: -160; } }
  }

  /* stats */
  .statbar { background: var(--paper); border-bottom: 1px solid var(--line); }
  .statbar .wrap { display: flex; flex-wrap: wrap; align-items: baseline; gap: 9px 0; padding: 13px 24px; }
  .stat { display: flex; align-items: baseline; gap: 8px; padding: 0 22px; border-left: 1px solid var(--line); }
  .stat:first-child { padding-left: 0; border-left: none; }
  .stat b { font-family: var(--serif); font-size: 21px; font-weight: 600; color: var(--ink); }
  .stat span { font-size: 12.5px; color: var(--sub); font-weight: 600; }

  .lead a { font-weight: 600; }

  /* challenges */
  .challenges { display: grid; grid-template-columns: repeat(5, 1fr); }
  @media (max-width: 980px) { .challenges { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 640px) { .challenges { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 440px) { .challenges { grid-template-columns: 1fr; } }
  .ch { padding: 20px 18px; border-left: 1px solid var(--line); color: var(--ink); }
  .ch:first-child { border-left: none; padding-left: 0; }
  .ch:hover { text-decoration: none; background: var(--card); }
  .ch .tag { font-size: 12px; font-weight: 700; color: var(--teal); }
  .ch h3 { font-size: 16px; margin: 8px 0 7px; line-height: 1.18; }
  .ch p { font-size: 12.5px; color: var(--sub); line-height: 1.5; }

  /* portal preview */
  .portal-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; align-items: stretch; }
  @media (max-width: 820px) { .portal-grid { grid-template-columns: 1fr; } }
  .panel { background: var(--card); border: 1px solid var(--line); border-radius: 6px; box-shadow: var(--shadow); overflow: hidden; }
  .panel-top { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 13px 16px; border-bottom: 1px solid var(--line); }
  .panel-top .ttl { font-family: var(--serif); font-weight: 600; font-size: 15.5px; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead th { font-size: 10.5px; letter-spacing: .06em; text-transform: uppercase; color: var(--faint); text-align: left; padding: 11px 16px 8px; font-weight: 700; }
  tbody td { padding: 10px 16px; border-top: 1px solid var(--line); }
  tbody tr:hover { background: var(--paper); }
  .dsname { font-weight: 600; }
  .map { position: relative; min-height: 240px; display: block; color: var(--ink); }
  .map svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .map:hover { text-decoration: none; }
  .pin { position: absolute; transform: translate(-50%, -100%); }
  .pin i { display: block; width: 13px; height: 13px; border-radius: 50% 50% 50% 0; transform: rotate(-45deg);
    box-shadow: 0 2px 5px rgba(0,0,0,.3), 0 0 0 3px color-mix(in srgb, var(--card) 70%, transparent); }
  .map-cta { position: absolute; right: 12px; bottom: 12px; font-size: 12.5px; font-weight: 700; color: var(--teal);
    background: color-mix(in srgb, var(--card) 90%, transparent); border: 1px solid var(--line); padding: 5px 10px; border-radius: 6px; }

  /* meetings */
  .mgrid { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--line); }
  @media (max-width: 760px) { .mgrid { grid-template-columns: 1fr; } }
  .mcard { padding: 20px; border-left: 1px solid var(--line); border-bottom: 1px solid var(--line); display: flex; flex-direction: column; gap: 7px; color: var(--ink); }
  .mcard:first-child { border-left: none; padding-left: 0; }
  @media (max-width: 760px) { .mcard { border-left: none; padding-left: 0; } }
  .mcard:hover { text-decoration: none; background: var(--card); }
  .mdate { font-size: 12px; color: var(--faint); font-weight: 700; }
  .mcard h3 { font-size: 17px; }
  .mloc { font-size: 13px; color: var(--sub); }
  .mfoot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; padding-top: 10px; }
  .talks { font-size: 11.5px; font-weight: 700; color: var(--teal-deep); background: var(--teal-soft); padding: 3px 9px; border-radius: 4px; }
  .go { font-size: 13px; font-weight: 700; color: var(--teal); }
  .meet-foot { margin-top: 20px; text-align: right; }
</style>
